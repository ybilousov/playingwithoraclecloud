# Copy this file to `.env` and fill in real secrets. Do NOT commit `.env`.
# Example values are placeholders only.

# Nginx Proxy Manager DB settings
DB_MYSQL_HOST=db
DB_MYSQL_PORT=3306
DB_MYSQL_USER=npm
DB_MYSQL_PASSWORD=replace_with_strong_password
DB_MYSQL_NAME=npm

# MariaDB root and user credentials for the DB container
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=npm
MYSQL_USER=npm
MYSQL_PASSWORD=replace_with_strong_password

# Optional: override exposed ports (if needed)
#HTTP_PORT=80
#ADMIN_UI_PORT=81
#HTTPS_PORT=443