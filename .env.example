# .env.example - Template for environment configuration
# ========================================================
# INSTRUCTIONS:
#   1. Copy this file to `.env`: `cp .env.example .env`
#   2. Update the values in `.env` with your configuration
#   3. DO NOT commit `.env` to version control (it's in .gitignore)
#   4. Use this file as a reference for all available configuration options

# ===== Nginx Proxy Manager Image =====
NPM_IMAGE=jc21/nginx-proxy-manager:latest

# ===== Port Mappings =====
# Map external ports to container ports
# Format: HOST_PORT:CONTAINER_PORT
HTTP_PORT=80
HTTPS_PORT=443
ADMIN_PORT=81

# ===== Database Image =====
DB_IMAGE=jc21/mariadb-aria:latest

# ===== Database Connection Settings =====
# Used by Nginx Proxy Manager to connect to the database
DB_MYSQL_HOST=db
DB_MYSQL_PORT=3306
DB_MYSQL_USER=npm
DB_MYSQL_PASSWORD=change_me_to_strong_password
DB_MYSQL_NAME=npm

# ===== MySQL Database Credentials =====
# Used by MariaDB container initialization
MYSQL_ROOT_PASSWORD=change_me_to_strong_root_password
MYSQL_DATABASE=npm
MYSQL_USER=npm
MYSQL_PASSWORD=change_me_to_strong_password

# ===== SECURITY RECOMMENDATIONS =====
# - Use strong passwords (minimum 16 characters, mixed case, numbers, symbols)
# - Change default passwords from example values
# - Rotate passwords periodically
# - Use unique passwords for root and application users