# .env.example - Template for environment configuration
# ========================================================
# INSTRUCTIONS:
#   1. Copy this file to `.env`: `cp .env.example .env`
#   2. Update the values in `.env` with your configuration
#   3. DO NOT commit `.env` to version control (it's in .gitignore)
#   4. Use this file as a reference for all available configuration options
#
# NOTE: NPM and WordPress stacks use SEPARATE databases with SEPARATE passwords
#       for security isolation. Update each password independently.

# ===== Nginx Proxy Manager Configuration =====
NPM_IMAGE=jc21/nginx-proxy-manager:latest

# ===== Port Mappings =====
HTTP_PORT=80
HTTPS_PORT=443
ADMIN_PORT=81

# ===== NPM Database Configuration (Isolated) =====
DB_IMAGE=jc21/mariadb-aria:latest
DB_MYSQL_HOST=db
DB_MYSQL_PORT=3306
DB_MYSQL_USER=npm
DB_MYSQL_PASSWORD=change_me_to_strong_password
DB_MYSQL_NAME=npm
MYSQL_ROOT_PASSWORD=change_me_to_strong_root_password
MYSQL_DATABASE=npm
MYSQL_USER=npm
MYSQL_PASSWORD=change_me_to_strong_password

# ===== WordPress Configuration =====
WP_IMAGE=wordpress:latest
WP_DB_IMAGE=mariadb:10.11

# ===== WordPress Database Configuration (Isolated) =====
# WordPress uses a separate MariaDB instance with its own root password
WP_DB_ROOT_PASSWORD=change_me_to_strong_password

# ===== WordPress Site Ports and Database Names =====
# Each site has its own database name on the shared WordPress MariaDB instance
WP_SITE1_PORT=8081
WP_SITE1_DB_NAME=wp_site_1_db

WP_SITE2_PORT=8082
WP_SITE2_DB_NAME=wp_site_2_db

WP_SITE3_PORT=8083
WP_SITE3_DB_NAME=wp_site_3_db

WP_SITE4_PORT=8084
WP_SITE4_DB_NAME=wp_site_4_db

# ===== SECURITY RECOMMENDATIONS =====
# - Use strong passwords (minimum 16 characters, mixed case, numbers, symbols)
# - Change default passwords from example values
# - Keep NPM and WordPress database passwords separate for security isolation
# - Rotate passwords periodically
# - Use unique passwords for root and application users